# ─── Google Sheets (CMS) ──────────────────────────────────────────────────────
# Base64-encoded service account JSON. Generate with:
#   base64 -i service-account.json | pbcopy
GOOGLE_SHEETS_CREDENTIALS=
# Spreadsheet ID from the URL: https://docs.google.com/spreadsheets/d/<THIS>/edit
GOOGLE_SHEETS_TOURS_ID=

# ─── Contact ──────────────────────────────────────────────────────────────────
# E.164 format, no leading +. Example: 5491141234567
NEXT_PUBLIC_WHATSAPP_NUMBER=
# Production base URL, no trailing slash. Example: https://motoonoff.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ─── Email (inquiry handler) ──────────────────────────────────────────────────
RESEND_API_KEY=
# Where new inquiry submissions are emailed.
INQUIRY_NOTIFICATION_EMAIL=

# ─── ISR / on-demand revalidation ─────────────────────────────────────────────
# Long random string. Used as a header secret for /api/revalidate.
REVALIDATE_SECRET=

# ─── Analytics ────────────────────────────────────────────────────────────────
# GA4 Measurement ID, e.g. G-XXXXXXXXXX
NEXT_PUBLIC_GA_ID=
